<section class="collection-rich section-{{ section.id }}">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="collection-rich__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <div class="collection-rich__text rte">
        {{ section.settings.text }}
      </div>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <div class="collection-rich__btn-wrap">
        <a href="{{ section.settings.button_link }}" class="collection-rich__btn">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

{% style %}
.section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* CONTAINER */
.collection-rich {
  text-align: center;
  background: {{ section.settings.bg_color }};
}

/* HEADING */
.collection-rich__heading {
  font-size: 36px;
  margin-bottom: 12px;
  color: {{ section.settings.heading_color }};
}

/* TEXT */
.collection-rich__text {
  max-width: 700px;
  margin: 0 auto 20px;
  font-size: 16px;
  color: {{ section.settings.text_color }};
  line-height: 1.6;
}

/* BUTTON */
.collection-rich__btn {
  display: inline-block;
  padding: 12px 26px;
  background: {{ section.settings.btn_bg }};
  color: {{ section.settings.btn_color }};
  text-decoration: none;
  border-radius: 4px;
  transition: 0.3s;
}

.collection-rich__btn:hover {
  opacity: 0.9;
}

/* MOBILE */
@media(max-width:768px){
  .collection-rich__heading {
    font-size: 24px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Collection Rich Content",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Timeless Sarees"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Content",
      "default": "<p>Explore our curated collection of sarees crafted with elegance, comfort, and timeless beauty — perfect for every occasion.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F8F5F1"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#6B6B6B"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button BG",
      "default": "#7A0F1D"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Text",
      "default": "#FFFFFF"
    },

    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 80,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 80,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Collection Rich Content"
    }
  ]
}
{% endschema %}