{% schema %}
{
  "name": "Saree Story Video",
  "settings": [
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Desktop Video"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Mobile Video"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Fallback Poster Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted by Hand, Woven with Legacy"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every saree carries the story of skilled artisans and timeless tradition"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Saree Story Video"
    }
  ]
}
{% endschema %}

<section class="saree-video-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  
  <div class="video-wrapper">
    
    {% if section.settings.video_desktop != blank %}
  <video
    class="video-desktop"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="{{ section.settings.poster | image_url }}"
  >
    <source src="{{ section.settings.video_desktop | video_tag: autoplay: false | split: 'src="' | last | split: '"' | first }}" type="video/mp4">
  </video>
{% endif %}

    {% if section.settings.video_mobile != blank %}
      <video
        class="video-mobile"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="{{ section.settings.poster | image_url: width: 800 }}"
      >
        <source src="{{ section.settings.video_mobile.sources[0].url }}" type="video/mp4">
      </video>
    {% endif %}

    <div class="overlay" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>

    <div class="content {{ section.settings.content_alignment }}">
      <h2 class="heading">{{ section.settings.heading }}</h2>
      <p class="subheading">{{ section.settings.subheading }}</p>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

  </div>
</section>

<style>
.saree-video-section {
  position: relative;
  overflow: hidden;
}

.video-wrapper {
  position: relative;
  width: 100%;
  height: 80vh;
}

.video-wrapper video {
  position: absolute;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-mobile {
  display: none;
}

.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
}

.content {
  position: relative;
  z-index: 2;
  max-width: 600px;
  padding: 20px;
}

.content.left {
  position: absolute;
  left: 8%;
  top: 50%;
  transform: translateY(-50%);
  text-align: left;
}

.content.center {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.heading {
  font-size: 42px;
  color: #fff;
  font-family: "Playfair Display", serif;
  margin-bottom: 15px;
}

.subheading {
  font-size: 16px;
  color: #eee;
  margin-bottom: 20px;
}

.btn {
  background: #d4af37;
  color: #000;
  padding: 12px 28px;
  text-decoration: none;
  font-size: 14px;
  transition: 0.3s ease;
}

.btn:hover {
  background: #b8962e;
}

@media (max-width: 768px) {
  .video-desktop {
    display: none;
  }

  .video-mobile {
    display: block;
  }

  .video-wrapper {
    height: 70vh;
  }

  .heading {
    font-size: 28px;
  }

  .content.left {
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
  }
}
</style>