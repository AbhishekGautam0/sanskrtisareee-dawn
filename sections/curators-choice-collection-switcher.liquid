  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<style>
  /* ===== CSS VARIABLES ===== */
  #shopify-section-{{ section.id }} {
    --cc-bg:               {{ section.settings.bg_color }};
    --cc-text-primary:     {{ section.settings.text_primary }};
    --cc-text-secondary:   {{ section.settings.text_secondary }};
    --cc-accent:           {{ section.settings.accent_color }};
    --cc-tab-text:         {{ section.settings.tab_text_color }};
    --cc-tab-active-text:  {{ section.settings.tab_active_text }};
    --cc-tab-underline:    {{ section.settings.tab_underline_color }};
    --cc-card-bg:          {{ section.settings.card_bg }};
    --cc-card-radius:      {{ section.settings.card_radius }}px;
    --cc-price-color:      {{ section.settings.price_color }};
    --cc-view-link-color:  {{ section.settings.view_link_color }};
    --cc-arrow-bg:         {{ section.settings.arrow_bg }};
    --cc-arrow-icon:       {{ section.settings.arrow_icon }};
    --cc-arrow-hover-bg:   {{ section.settings.arrow_hover_bg }};
    --cc-arrow-hover-icon: {{ section.settings.arrow_hover_icon }};
    --cc-dot-color:        {{ section.settings.dot_color }};
    --cc-dot-active:       {{ section.settings.dot_active_color }};
    --cc-pad-top:          {{ section.settings.padding_top }}px;
    --cc-pad-bottom:       {{ section.settings.padding_bottom }}px;
    --cc-max-width:        {{ section.settings.max_width }}px;
    --cc-h-pad:            {{ section.settings.padding_h }}px;
  }

  /* ===== WRAPPER ===== */
  .cc-section {
    background: var(--cc-bg);
    padding-top: var(--cc-pad-top);
    padding-bottom: var(--cc-pad-bottom);
    overflow: hidden;
  }

  .cc-inner {
    max-width: var(--cc-max-width);
    margin: 0 auto;
    padding: 0 var(--cc-h-pad);
  }

  /* ===== HEADER ROW ===== */
  .cc-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: {{ section.settings.header_mb }}px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .cc-heading {
    font-family: {{ font_heading.family }}, serif;
    font-weight: {{ section.settings.heading_weight }};
    font-size: {{ section.settings.heading_size }}px;
    color: var(--cc-text-primary);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .cc-view-link {
    font-family: {{ font_tab.family }}, sans-serif;
    font-size: {{ section.settings.view_link_size }}px;
    font-weight: {{ section.settings.view_link_weight }};
    color: var(--cc-view-link-color);
    text-decoration: none;
    white-space: nowrap;
    padding-top: 6px;
    letter-spacing: 0.01em;
    transition: opacity 0.2s;
  }

  .cc-view-link:hover {
    opacity: 0.7;
  }

  /* ===== TABS ===== */
  .cc-tabs-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid {{ section.settings.tab_divider_color }};
    margin-bottom: {{ section.settings.tabs_mb }}px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .cc-tabs-row::-webkit-scrollbar { display: none; }

  .cc-tabs {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cc-tab-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: {{ font_tab.family }}, sans-serif;
    font-size: {{ section.settings.tab_font_size }}px;
    font-weight: {{ section.settings.tab_font_weight }};
    color: var(--cc-tab-text);
    padding: {{ section.settings.tab_pad_v }}px {{ section.settings.tab_pad_h }}px;
    padding-left: 0;
    margin-right: {{ section.settings.tab_gap }}px;
    position: relative;
    white-space: nowrap;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }

  .cc-tab-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: {{ section.settings.tab_underline_height }}px;
    background: var(--cc-tab-underline);
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: left;
  }

  .cc-tab-btn.is-active {
    color: var(--cc-tab-active-text);
  }

  .cc-tab-btn.is-active::after {
    transform: scaleX(1);
  }

  .cc-tab-btn:hover {
    color: var(--cc-tab-active-text);
  }

  /* ===== TAB PANELS ===== */
  .cc-tab-panel {
    display: none;
    overflow: 
  }
    .cc-inner .splide__track {
    overflow: hidden;
  }


  .cc-tab-panel.is-active {
    display: block;
  }

  /* ===== PRODUCT CARD ===== */
  .cc-product-card {
    {% comment %} background: var(--cc-card-bg); {% endcomment %}
    border-radius: var(--cc-card-radius);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    {% comment %} height: 100%; {% endcomment %}
  }

  .cc-product-card:hover {
    transform: translateY(-4px);
    {% comment %} box-shadow: 0 16px 48px rgba(0,0,0,0.08); {% endcomment %}
  }

  .cc-img-wrap {
    position: relative;
    width: 100%;
    {% comment %} padding-bottom: {{ section.settings.image_ratio }}%; {% endcomment %}
    overflow: hidden;
    {% comment %} background: {{ section.settings.img_placeholder_bg }}; {% endcomment %}
  }

  .cc-img-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .cc-product-card:hover .cc-img-wrap img {
    transform: scale(1.05);
  }
  .cc-product-card .button:after {
    content: unset;
  }
  .cc-product-card .quick-add__submit {
    {% comment %} background: var(--cc-card-bg);
    color: var(--cc-price-color); {% endcomment %}
    border: 1px solid #fff;
  }
  .cc-product-card .card__heading {
    font-size: 18px;
  }
  /* ===== BADGES ===== */
  .cc-badge {
    position: absolute;
    top: {{ section.settings.badge_top }}px;
    left: {{ section.settings.badge_left }}px;
    z-index: 2;
    font-family: {{ font_tab.family }}, sans-serif;
    font-size: {{ section.settings.badge_font_size }}px;
    font-weight: {{ section.settings.badge_font_weight }};
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: {{ section.settings.badge_pad_v }}px {{ section.settings.badge_pad_h }}px;
    border-radius: {{ section.settings.badge_radius }}px;
    white-space: nowrap;
  }

  .cc-badge--new {
    background: {{ section.settings.badge_new_bg }};
    color: {{ section.settings.badge_new_text }};
  }

  .cc-badge--limited {
    background: {{ section.settings.badge_limited_bg }};
    color: {{ section.settings.badge_limited_text }};
  }

  .cc-badge--low-stock {
    background: {{ section.settings.badge_lowstock_bg }};
    color: {{ section.settings.badge_lowstock_text }};
  }

  /* ===== CARD INFO ===== */
  .cc-card-info {
    padding: {{ section.settings.card_info_pad }}px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .cc-product-name {
    font-family: {{ font_body.family }}, sans-serif;
    font-size: {{ section.settings.product_name_size }}px;
    font-weight: {{ section.settings.product_name_weight }};
    color: var(--cc-text-primary);
    margin: 0 0 6px;
    line-height: 1.3;
  }

  .cc-product-price {
    font-family: {{ font_body.family }}, sans-serif;
    font-size: {{ section.settings.price_size }}px;
    font-weight: {{ section.settings.price_weight }};
    color: var(--cc-price-color);
    margin: 0;
  }

  /* ===== SPLIDE SLIDER ===== */
  .cc-splide .splide__track {
    {% comment %} overflow: visible; {% endcomment %}
  }

  .cc-splide .splide__slide {
    height: auto;
  }

  .cc-splide .splide__arrow {
    background: var(--cc-arrow-bg);
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: 50%;
    opacity: 1;
    border: 1px solid {{ section.settings.arrow_border }};
    transition: background 0.2s;
  }

  .cc-splide .splide__arrow svg {
    fill: var(--cc-arrow-icon);
    width: 14px;
    height: 14px;
  }

  .cc-splide .splide__arrow:hover {
    background: var(--cc-arrow-hover-bg);
  }

  .cc-splide .splide__arrow:hover svg {
    fill: var(--cc-arrow-hover-icon);
  }

  .cc-splide .splide__arrow--prev {
    left: -{{ section.settings.arrow_offset }}px;
  }

  .cc-splide .splide__arrow--next {
    right: -{{ section.settings.arrow_offset }}px;
  }

  .cc-splide .splide__pagination {
    bottom: -32px;
  }

  .cc-splide .splide__pagination__page {
    background: var(--cc-dot-color);
    opacity: 0.35;
    width: 6px;
    height: 6px;
    transition: all 0.3s;
  }

  .cc-splide .splide__pagination__page.is-active {
    background: var(--cc-dot-active);
    opacity: 1;
    transform: scale(1.4);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .cc-header {
      flex-direction: column;
      gap: 8px;
    }

    .cc-heading {
      font-size: {{ section.settings.heading_size | times: 0.68 | round }}px;
    }

    .cc-splide .splide__arrow--prev {
      left: 4px;
    }

    .cc-splide .splide__arrow--next {
      right: 4px;
    }
    .cc-inner {
      padding-right: 0
    }

    .cc-section {
      padding-top: calc(var(--cc-pad-top) * 0.75);
      padding-bottom: calc(var(--cc-pad-bottom) * 0.75);
    }

  }
</style>

<section class="cc-section" id="shopify-section-{{ section.id }}-inner">
  <div class="cc-inner">

    {%- comment -%} HEADER ROW {%- endcomment -%}
    <div class="cc-header">
      <h2 class="cc-heading">{{ section.settings.heading }}</h2>
      {% if section.settings.view_all_label != blank and section.settings.view_all_url != blank %}
        <a href="{{ section.settings.view_all_url }}" class="cc-view-link">
          {{ section.settings.view_all_label }}
        </a>
      {% endif %}
    </div>

    {%- comment -%} TABS {%- endcomment -%}
    <div class="cc-tabs-row">
      <ul class="cc-tabs" role="tablist">
        {% for block in section.blocks %}
          {% if block.type == 'collection_tab' %}
            <li role="presentation">
              <button
                class="cc-tab-btn{% if forloop.first %} is-active{% endif %}"
                role="tab"
                data-tab="cc-panel-{{ section.id }}-{{ forloop.index }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                {{ block.settings.tab_label | default: block.settings.collection.title }}
              </button>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    {%- comment -%} TAB PANELS {%- endcomment -%}
    {% for block in section.blocks %}
      {% if block.type == 'collection_tab' %}
        {%- assign tab_collection = collections[block.settings.collection] -%}

        <div
          class="cc-tab-panel{% if forloop.first %} is-active{% endif %}"
          id="cc-panel-{{ section.id }}-{{ forloop.index }}"
          role="tabpanel"
        >
          <div
            class="splide cc-splide"
            id="cc-splide-{{ section.id }}-{{ forloop.index }}"
            aria-label="{{ block.settings.tab_label | default: tab_collection.title }}"
          >
            <div class="splide__track">
              <ul class="splide__list">
                             {% assign skip_card_product_styles = false %}

                {% assign lazy_load = false %}
                {% if tab_collection != blank %}
                  {% for product in tab_collection.products limit: section.settings.products_limit %}
                    {% if lazy_load == false and forloop.index > section.settings.products_to_show %}
                {% assign lazy_load = true %}
              {% endif %}

                    <li class="splide__slide">
                      <div  class="cc-product-card">
                        <div class="cc-img-wrap">
                          {% if product.featured_image %}
                             {% render 'card-product',
                          card_product: product,
                          media_aspect_ratio: section.settings.image_ratio,
                          image_shape: section.settings.image_shape,
                          lazy_load: lazy_load,
                          show_secondary_image: section.settings.show_secondary_image,
                          show_vendor: section.settings.show_vendor,
                          show_rating: section.settings.show_rating,
                          skip_styles: skip_card_product_styles,
                          section_id: section.id,
                          quick_add: section.settings.quick_add
                        %}
                         {%- assign skip_card_product_styles = true -%}
                            {% comment %} {%- assign alt_text = product.featured_image.alt | escape -%}
                            {{ product.featured_image | image_url: width: 800 | image_tag:
                              loading: 'lazy',
                              alt: alt_text,
                              widths: '300, 500, 700'
                            }} {% endcomment %}
                          {% else %}
                            {{ 'product-1' | placeholder_svg_tag }}
                          {% endif %}

                          {%- comment -%} Badge Logic — uses product tags {%- endcomment -%}
                          {% if product.tags contains section.settings.tag_new %}
                            <span class="cc-badge cc-badge--new">{{ section.settings.badge_new_label }}</span>
                          {% elsif product.tags contains section.settings.tag_limited %}
                            <span class="cc-badge cc-badge--limited">{{ section.settings.badge_limited_label }}</span>
                          {% elsif product.available == false %}
                            <span class="cc-badge cc-badge--low-stock">{{ section.settings.badge_sold_out_label }}</span>
                          {% elsif product.variants.first.inventory_quantity > 0 and product.variants.first.inventory_quantity <= section.settings.low_stock_threshold %}
                            <span class="cc-badge cc-badge--low-stock">
                              {{ section.settings.badge_lowstock_label | replace: '[qty]', product.variants.first.inventory_quantity }}
                            </span>
                          {% endif %}
                        </div>

                        {% comment %} <div class="cc-card-info">
                          <p class="cc-product-name">{{ product.title }}</p>
                          <p class="cc-product-price">{{ product.price | money }}</p>
                        </div> {% endcomment %}
                      </div>
                    </li>
                  {% endfor %}

                {% else %}
                  {%- comment -%} Placeholder when no collection {%- endcomment -%}
                  {% for i in (1..4) %}
                    <li class="splide__slide">
                      <div class="cc-product-card">
                        <div class="cc-img-wrap">
                          {{ 'product-' | append: i | placeholder_svg_tag }}
                          {% if i == 1 %}
                            <span class="cc-badge cc-badge--new">{{ section.settings.badge_new_label }}</span>
                          {% elsif i == 2 %}
                            <span class="cc-badge cc-badge--limited">{{ section.settings.badge_limited_label }}</span>
                          {% elsif i == 4 %}
                            <span class="cc-badge cc-badge--low-stock">{{ section.settings.badge_lowstock_label | replace: '[qty]', '2' }}</span>
                          {% endif %}
                        </div>
                        <div class="cc-card-info">
                          <p class="cc-product-name">Sample Saree {{ i }}</p>
                          <p class="cc-product-price">$1,800</p>
                        </div>
                      </div>
                    </li>
                  {% endfor %}
                {% endif %}

              </ul>
            </div>

            {% if section.settings.show_arrows %}<div class="splide__arrows"></div>{% endif %}
            {% if section.settings.show_pagination %}<ul class="splide__pagination"></ul>{% endif %}
          </div>
        </div>

      {% endif %}
    {% endfor %}

  </div>
</section>


<script>
(function () {
  var sectionId = '{{ section.id }}';

  function initSplides() {
    var sliderConfig = {
      type        : '{{ section.settings.slider_type }}',
      perPage     : {{ section.settings.slides_desktop }},
      perMove     : {{ section.settings.slides_per_move }},
      gap         : '{{ section.settings.slide_gap }}px',
      arrows      : {{ section.settings.show_arrows }},
      pagination  : {{ section.settings.show_pagination }},
      autoplay    : {{ section.settings.autoplay }},
      interval    : {{ section.settings.autoplay_speed }},
      pauseOnHover: {{ section.settings.pause_on_hover }},
      rewind      : {{ section.settings.rewind }},
      speed       : {{ section.settings.transition_speed }},
      easing      : '{{ section.settings.transition_easing }}',
      drag        : {{ section.settings.drag }},
      snap        : true,
      padding     : { right: '{{ section.settings.peek_desktop }}px' },
      breakpoints : {
        1024: {
          perPage : {{ section.settings.slides_tablet }},
          gap     : '{{ section.settings.slide_gap_tablet }}px',
          padding : { right: '{{ section.settings.peek_tablet }}px' },
        },
        768: {
          perPage : {{ section.settings.slides_mobile }},
          gap     : '{{ section.settings.slide_gap_mobile }}px',
          padding : { right: '{{ section.settings.peek_mobile }}px' },
          arrows  : {{ section.settings.show_arrows_mobile }},
        },
      },
    };

    document.querySelectorAll('.cc-tab-panel').forEach(function (panel, index) {
      var splideEl = panel.querySelector('.cc-splide');
      if (splideEl && !splideEl.classList.contains('is-initialized')) {
        splideEl.classList.add('is-initialized');
        new Splide(splideEl, sliderConfig).mount();
      }
    });
  }

  // Tabs logic
  function initTabs() {
    var tabBtns = document.querySelectorAll('#shopify-section-' + sectionId + ' .cc-tab-btn');
    tabBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var targetId = btn.getAttribute('data-tab');

        // Deactivate all
        tabBtns.forEach(function (b) {
          b.classList.remove('is-active');
          b.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('#shopify-section-' + sectionId + ' .cc-tab-panel').forEach(function (p) {
          p.classList.remove('is-active');
        });

        // Activate target
        btn.classList.add('is-active');
        btn.setAttribute('aria-selected', 'true');
        var panel = document.getElementById(targetId);
        if (panel) {
          panel.classList.add('is-active');
          // Init splide inside newly shown panel
          var splideEl = panel.querySelector('.cc-splide');
          if (splideEl && !splideEl.classList.contains('is-initialized')) {
            splideEl.classList.add('is-initialized');
            new Splide(splideEl, {
              type        : '{{ section.settings.slider_type }}',
              perPage     : {{ section.settings.slides_desktop }},
              perMove     : {{ section.settings.slides_per_move }},
              gap         : '{{ section.settings.slide_gap }}px',
              arrows      : {{ section.settings.show_arrows }},
              pagination  : {{ section.settings.show_pagination }},
              autoplay    : {{ section.settings.autoplay }},
              interval    : {{ section.settings.autoplay_speed }},
              pauseOnHover: {{ section.settings.pause_on_hover }},
              rewind      : {{ section.settings.rewind }},
              speed       : {{ section.settings.transition_speed }},
              easing      : '{{ section.settings.transition_easing }}',
              drag        : {{ section.settings.drag }},
              snap        : true,
              padding     : { right: '{{ section.settings.peek_desktop }}px' },
              breakpoints : {
                1024: {
                  perPage : {{ section.settings.slides_tablet }},
                  gap     : '{{ section.settings.slide_gap_tablet }}px',
                  padding : { right: '{{ section.settings.peek_tablet }}px' },
                },
                768: {
                  perPage : {{ section.settings.slides_mobile }},
                  gap     : '{{ section.settings.slide_gap_mobile }}px',
                  padding : { right: '{{ section.settings.peek_mobile }}px' },
                  arrows  : {{ section.settings.show_arrows_mobile }},
                },
              },
            }).mount();
          }
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    initSplides();
    initTabs();
  });
})();
</script>

{% schema %}
{
  "name": "Collection Switcher",
  "tag": "section",
  "class": "section-curators-choice",
  "max_blocks": 5,
  "settings": [

    {
      "type": "header",
      "content": "✏️ Header Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "The Curator's Choice"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Link Label",
      "default": "View Full Gallery"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All Link URL"
    },

    {
      "type": "header",
      "content": "🔖 Badge Settings"
    },
    {
      "type": "text",
      "id": "tag_new",
      "label": "Product Tag → New Arrival Badge",
      "default": "new-arrival",
      "info": "Add this tag to products in Shopify admin to show the badge"
    },
