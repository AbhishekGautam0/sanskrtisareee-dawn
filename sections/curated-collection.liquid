{% comment %}
  Curated Collection - Splide Slider Section
  - Lazy loading via Splide's native lazy load (data-splide-lazy)
  - No render-blocking: Splide loaded with defer
  - LCP-safe: first slide image is eagerly loaded, rest are lazy
  - Fully responsive
{% endcomment %}

<section class="curated-collection section-{{ section.id }}-padding" id="curated-collection-{{ section.id }}">
  <div class="curated-collection__inner">

    {% if section.settings.heading != blank %}
      <h2 class="curated-collection__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="splide curated-splide" aria-label="{{ section.settings.heading | escape }}">
       {% if section.settings.show_arrows %}
        <div class="splide__arrows curated-splide__arrows">
          <button class="splide__arrow splide__arrow--prev curated-arrow" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="splide__arrow splide__arrow--next curated-arrow" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      {% endif %}

      <div class="splide__track">
        <ul class="splide__list">

          {% for block in section.blocks %}
            {% assign is_first = false %}
            {% if forloop.first %}{% assign is_first = true %}{% endif %}

            <li class="splide__slide" {{ block.shopify_attributes }}>
              <a
                class="curated-card"
                href="{{ block.settings.link | default: '#' }}"
                aria-label="{{ block.settings.label | escape }}"
              >
                <div class="curated-card__image-wrap">
                  {%- if block.settings.image != blank -%}
                    {%- if is_first -%}
                      {{
                        block.settings.image
                        | image_url: width: 600
                        | image_tag:
                          loading: 'eager',
                          fetchpriority: 'high',
                          widths: '300, 400, 600',
                          sizes: '(max-width: 640px) 45vw, (max-width: 1024px) 22vw, 200px',
                          class: 'curated-card__img',
                          alt: block.settings.label | escape
                      }}
                    {%- else -%}
                      {{
                        block.settings.image
                        | image_url: width: 600
                        | image_tag:
                          loading: 'lazy',
                          widths: '300, 400, 600',
                          sizes: '(max-width: 640px) 45vw, (max-width: 1024px) 22vw, 200px',
                          class: 'curated-card__img',
                          alt: block.settings.label | escape
                      }}
                    {%- endif -%}
                  {%- else -%}
                    <div class="curated-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'curated-card__placeholder-svg' }}
                    </div>
                  {%- endif -%}

                  <div class="curated-card__badge-wrap">
                    <span class="curated-card__badge">{{ block.settings.badge_text }}</span>
                  </div>
                </div>

                {% if block.settings.label != blank %}
                  <p class="curated-card__label">{{ block.settings.label }}</p>
                {% endif %}
              </a>
            </li>
          {% endfor %}

        </ul>
      </div>

     

    </div><!-- .splide -->
  </div>
</section>

{% comment %} ===================== STYLES ===================== {% endcomment %}
<style>
  #curated-collection-{{ section.id }} {
    --cc-bg:         {{ section.settings.bg_color }};
    --cc-heading:    {{ section.settings.heading_color }};
    --cc-label:      {{ section.settings.label_color }};
    --cc-badge-bg:   {{ section.settings.badge_bg_color }};
    --cc-badge-text: {{ section.settings.badge_text_color }};
    --cc-arrow-bg:   {{ section.settings.arrow_bg_color }};
    --cc-arrow-icon: {{ section.settings.arrow_icon_color }};
    --cc-underline:  {{ section.settings.heading_underline_color }};
    --cc-gap:        {{ section.settings.slide_gap }}px;
    --cc-radius:     {{ section.settings.card_radius }}px;
  }

  .curated-collection {
    background-color: var(--cc-bg);
    overflow: hidden;
  }
   .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.section_padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.section_padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .curated-collection__inner {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .curated-collection__heading {
    font-family: Georgia, serif;
    
    color: var(--cc-heading);
    margin: 0 0 24px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--cc-underline);
    display: inline-block;
    font-weight: normal;
    font-style: italic;
  }

  /* ---- Card ---- */
  .curated-card {
    display: block;
    text-decoration: none;
    text-align: center;
  }

  .curated-card__image-wrap {
    position: relative;
    border-radius: var(--cc-radius);
    overflow: hidden;
    /* Ornate badge-style clip matching design */
    clip-path: polygon(
      12% 0%, 88% 0%,
      100% 12%, 100% 75%,
      88% 88%, 75% 100%,
      50% 95%, 25% 100%,
      12% 88%, 0% 75%,
      0% 12%
    );
    aspect-ratio: 3 / 4;
    background: #1a1007;
  }

  .curated-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .curated-card:hover .curated-card__img {
    transform: scale(1.06);
  }

  /* Gradient overlay */
  .curated-card__image-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 35%,
      rgba(60, 20, 5, 0.82) 100%
    );
    pointer-events: none;
  }

  /* Badge overlay inside card */
  .curated-card__badge-wrap {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
  }

  .curated-card__badge {
    display: block;
    color: var(--cc-badge-text);
    background: var(--cc-badge-bg);
    font-size: clamp(0.6rem, 1.2vw, 0.75rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    padding: 6px 10px;
    border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 4px;
  }

  /* Label below card */
  .curated-card__label {
    margin: 10px 0 0;
    font-size: clamp(0.72rem, 1.3vw, 1.85rem);
    color: var(--cc-label);
    letter-spacing: 0.03em;
  }

  .curated-card__placeholder {
    width: 100%;
    height: 100%;
    background: #ccc;
  }
  .curated-card__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---- Arrows ---- */
  .curated-splide__arrows {
    position: absolute;
    width: 100%;
    top: 45%;
  }

  .curated-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--cc-arrow-bg) !important;
    color: var(--cc-arrow-icon) !important;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 1 !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.18);
    transition: transform 0.2s;
  }
  {% comment %} .curated-arrow:hover {
    transform: scale(1.1);
  } {% endcomment %}
  .curated-arrow svg {
    pointer-events: none;
    fill: none;
  }
  .curated-collection .splide__arrow--prev {
    left: -1em;
    rotate: 180deg;
  }
  .curated-collection .splide__arrow--next {
    right: -1em;
  }

  /* Splide overrides */
  {% comment %} .splide__arrow svg { display: none; } {% endcomment %}

   @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.section_padding_top }}px;
      padding-bottom: {{ section.settings.section_padding_bottom }}px;
    }
  }
  @media (max-width: 640px) {
    .curated-collection__inner { padding: 0 12px; }
  .curated-collection .splide__arrow--prev {
    left: 1em;
    top: -4rem;
  }
  .curated-collection .splide__arrow--next {
    right: 1em;
  }
   .curated-card__label {
    font-size: 16px;
  }
  .curated-card__badge {
    font-size: 12px;
  }

  .curated-card__badge-wrap {
    bottom: 35px;
  }
 }
</style>

{% comment %} ===================== SPLIDE JS ===================== {% endcomment %}
<script>
  (function () {
    /* Load Splide only once across multiple sections */
    function initSplide() {
      var el = document.querySelector('#curated-collection-{{ section.id }} .curated-splide');
      if (!el || el._splideInit) return;
      el._splideInit = true;

      new Splide(el, {
        type:        'loop',
        perPage:     {{ section.settings.slides_desktop }},
        perMove:     1,
        gap:         '{{ section.settings.slide_gap }}px',
        pagination:  {{ section.settings.show_dots }},
        arrows:      {{ section.settings.show_arrows }},
        autoplay:    {{ section.settings.autoplay }},
        interval:    {{ section.settings.autoplay_speed | times: 1000 }},
        pauseOnHover: true,
        lazyLoad:    'nearby',
        preloadPages: 1,
        breakpoints: {
          1024: { perPage: {{ section.settings.slides_tablet }} },
          640:  { perPage: {{ section.settings.slides_mobile }}, gap: '10px',padding     : { right: '32px' }, }
        }
      }).mount();
    }

    function loadSplide(cb) {
      if (window.Splide) { cb(); return; }

      /* CSS */
      if (!document.getElementById('splide-css')) {
        var link = document.createElement('link');
        link.id   = 'splide-css';
        link.rel  = 'stylesheet';
        link.href = 'https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css';
        document.head.appendChild(link);
      }

      /* JS */
      if (!document.getElementById('splide-js')) {
        var script   = document.createElement('script');
        script.id    = 'splide-js';
        script.defer = true;
        script.src   = 'https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js';
        script.onload = cb;
        document.head.appendChild(script);
      } else {
        /* Script tag exists but may still be loading */
        document.getElementById('splide-js').addEventListener('load', cb);
      }
    }

    /* Use IntersectionObserver for deferred init — zero LCP impact */
    var section = document.getElementById('curated-collection-{{ section.id }}');
    if (!section) return;

    var observer = new IntersectionObserver(function (entries, obs) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          obs.disconnect();
          loadSplide(initSplide);
        }
      });
    }, { rootMargin: '200px' });

    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "Curated Collection",
  "tag": "section",
  "class": "curated-collection-section",
  "max_blocks": 12,
  "settings": [
    {
