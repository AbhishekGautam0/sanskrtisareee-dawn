{% style %}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
  }

  .section-{{ section.id }} .container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* DESKTOP GRID */
  .grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 16px;
  }

  /* MOBILE SLIDER */
  .splide-{{ section.id }} {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .grid-{{ section.id }} {
      display: none;
    }
    .splide-{{ section.id }} {
      display: block;
    }
  }

  /* CARD */
  .card-{{ section.id }} {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
  }

  .card-{{ section.id }} img {
    width: 100%;
    height: 350px;
    max-height: 450px;
    object-fit: cover;
    border-radius: 16px;
  }

  /* OVERLAY TEXT */
  .overlay-{{ section.id }} {
    position: absolute;
    bottom: 20px;
    left: 20px;
    color: #fff;
    font-size: 22px;
    font-weight: 600;
  }

  /* CIRCLE STRIP */
  .circle-strip-{{ section.id }} {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 16px;
    background: #f4f4f4;
    padding: 16px 24px;
    border-radius: 40px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow-x: auto;
  }

  .circle-item-{{ section.id }} {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .circle-item-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .section-{{ section.id }} .main-heading.center.h1 {
    margin-bottom: 15px;
  }

  @media(max-width: 650px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }
{% endstyle %}

<div class="section-{{ section.id }}">
  <div class="container">
    <h1 class="main-heading center h1">{{ section.settings.heading | default: 'Shop By Collections' }}</h1>
    <!-- DESKTOP GRID -->
    <div class="grid-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        <a href="{{ collection.url }}" class="card-{{ section.id }}">
          {% if collection.image != blank %}
            {% assign image_obj = collection.image | default: block.settings.fallback_image %}

              {% if image_obj != blank %}
                <img
                  src="{{ image_obj | image_url: width: 500 }}"
                  srcset="
                    {{ image_obj | image_url: width: 400 }} 400w,
                    {{ image_obj | image_url: width: 600 }} 600w,
                    {{ image_obj | image_url: width: 800 }} 800w
                  "
                  sizes="(max-width: 768px) 90vw, (max-width: 1200px) 30vw, 400px"
                  width="{{ image_obj.width }}"
                  height="{{ image_obj.height }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  decoding="async"
                >
              {% endif %}
          {% else %}
            <img src="{{ block.settings.fallback_image | image_url: width: 1000 }}">
          {% endif %}

          <div class="overlay-{{ section.id }}">
            {{ block.settings.custom_title | default: collection.title }}
          </div>
        </a>
      {% endfor %}
    </div>

    <!-- MOBILE SPLIDE -->
    <div class="splide splide-{{ section.id }}">
      <div class="splide__track">
        <div class="splide__list">
          {% for block in section.blocks %}
            {% assign collection = collections[block.settings.collection] %}
            <div class="splide__slide">
              <a href="{{ collection.url }}" class="card-{{ section.id }}">
                {% assign image_obj = collection.image | default: block.settings.fallback_image %}

                {% if image_obj != blank %}
                  {% assign image_obj = collection.image | default: block.settings.fallback_image %}

{% if image_obj != blank %}
  <img
    src="{{ image_obj | image_url: width: 500 }}"
    srcset="
      {{ image_obj | image_url: width: 400 }} 400w,
      {{ image_obj | image_url: width: 600 }} 600w,
      {{ image_obj | image_url: width: 800 }} 800w
    "
    sizes="(max-width: 768px) 90vw, (max-width: 1200px) 30vw, 400px"
    width="{{ image_obj.width }}"
    height="{{ image_obj.height }}"
    alt="{{ collection.title | escape }}"
    loading="lazy"
    decoding="async"
  >
{% endif %}
                {% endif %}

                <div class="overlay-{{ section.id }}">
                  {{ block.settings.custom_title | default: collection.title }}
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- CIRCLE STRIP -->
    {% comment %}
      <div class="circle-strip-{{ section.id }}">
        {% for block in section.blocks %}
          {% assign collection = collections[block.settings.collection] %}
          <a href="{{ collection.url }}" class="circle-item-{{ section.id }}">
            {% if collection.image != blank %}
              <img src="{{ collection.image | image_url: width: 200 }}">
            {% else %}
              <img src="{{ block.settings.fallback_image | image_url: width: 200 }}">
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endcomment %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Splide('.splide-{{ section.id }}', {
      type: 'loop',
      perPage: 1,
      gap: '10px',
      arrows: false,
      pagination: true,
      autoplay: false,

      breakpoints: {
        749: {
          autoplay: true,
          interval: 3000, // 3 seconds
          pauseOnHover: false,
          pauseOnFocus: false,
        }
      }
    }).mount();
  });
</script>

{% schema %}
{
  "name": "Premium Collection Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Section Heading"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop Columns",
      "min": 2,
      "max": 4,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "fallback_image", "label": "Fallback Image" },
        { "type": "text", "id": "custom_title", "label": "Custom Title" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Collection Slider"
    }
  ]
}
{% endschema %}
