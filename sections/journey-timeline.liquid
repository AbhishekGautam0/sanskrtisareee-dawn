      "id": "item_desc_size",
      "min": 13,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Description Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "desc_max_width",
      "min": 200,
      "max": 520,
      "step": 10,
      "unit": "px",
      "default": 360,
      "label": "Description Max Width",
    },

    {
      "type": "header",
      "content": " Layout & Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1200,
      "label": "Section Max Width",
    },
    {
      "type": "range",
      "id": "centre_col_width",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64,
      "label": "Centre Column Width (dot area)",
    },
    {
      "type": "range",
      "id": "item_gap",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60,
      "label": "Gap Between Milestones",
    },
    {
      "type": "range",
      "id": "cell_pad_v",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16,
      "label": "Cell Vertical Padding",
    },
    {
      "type": "range",
      "id": "cell_pad_h",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32,
      "label": "Cell Horizontal Padding",
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 10,
      "label": "Gap: Title → Description",
    },
    {
      "type": "range",
      "id": "timeline_pad_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0,
      "label": "Timeline Top Padding",
    },
    {
      "type": "range",
      "id": "timeline_pad_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0,
      "label": "Timeline Bottom Padding",
    },
    {
      "type": "range",
      "id": "pad_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80,
      "label": "Section Top Padding",
    },
