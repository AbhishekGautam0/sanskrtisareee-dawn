        { "value": "300", "label": "Light"   },
        { "value": "400", "label": "Regular" },
        { "value": "700", "label": "Bold"    }
      ],
      "default": "300"
    },
    {
      "type": "range",
      "id": "item_title_size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Milestone Title Size",
      "default": 22
    },
    {
