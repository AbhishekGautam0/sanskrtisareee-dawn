      "id": "heading_weight",
      "label": "Section Heading Weight",
      "options": [
        { "value": "300", "label": "Light"     },
        { "value": "400", "label": "Regular"   },
        { "value": "500", "label": "Medium"    },
        { "value": "700", "label": "Bold"      }
      ],
      "default": "400"
    },
    {
      "type": "font_picker",
      "id": "year_font",
