    {
      "type": "checkbox",
      "id": "dot_ring",
      "label": "Show Ring Around Dot",
      "default": false
    },
    {
      "type": "color",
      "id": "dot_ring_color",
      "label": "Dot Ring Color",
      "default": "#c9b89a"
    },
    {
      "type": "checkbox",
      "id": "show_connector",
      "label": "Show Horizontal Connector Line",
      "default": false
    },
    {
      "type": "range",
      "id": "connector_length",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Connector Length",
      "default": 32
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading / Title Font",
      "default": "playfair_display_n4"
    },
