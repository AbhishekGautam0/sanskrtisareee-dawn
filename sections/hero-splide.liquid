{% style %}
  .hero-{{ section.id }} {
    position: relative;
    min-height: 550px;
  }

  /* CLS SAFE */
  .hero-slide-{{ section.id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.aspect_ratio }};
    overflow: hidden;
  }

  /* IMAGE */
  .hero-slide-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* OVERLAY */
  .hero-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity }});
    display: block !important;
  }

  /* CONTENT */
  .hero-content-{{ section.id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    max-width: 520px;
    color: {{ section.settings.text_color }};
    z-index: 2;
  }

  /* ALIGNMENT */
  .align-left { left: 8%; text-align: left; }
  .align-center { left: 50%; transform: translate(-50%, -50%); text-align: center; }
  .align-right { right: 8%; text-align: right; }

  /* TEXT */
  .hero-heading-{{ section.id }} {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 600;
    margin-bottom: 10px;
    color: {{section.settings.text_color }};
  }

  .hero-text-{{ section.id }} {
    font-size: {{ section.settings.text_size }}px;
    margin-bottom: 20px;
    color: {{section.settings.text_color }};
  }

  /* BUTTON */
  .hero-btn-{{ section.id }} {
    display: inline-block;
    padding: 12px 28px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_color }};
    text-decoration: none;
    border-radius: 4px;
  }

  /* MOBILE */
  @media(max-width:768px){
    .hero-content-{{ section.id }} {
      left: 20px !important;
      right: 20px !important;
      text-align: center !important;
      top: 70%;
    }

    .hero-heading-{{ section.id }} {
      font-size: 22px;
    }
    .hero-slide-{{ section.id }} {
      aspect-ratio: 1/2;
      max-height: 560px;
      object-fit: cover;
    }
  }
{% endstyle %}

<div class="hero-{{ section.id }}">
  <div class="splide splide-hero-{{ section.id }}">
    <div class="splide__track">
      <div class="splide__list">
        {% for block in section.blocks %}
          
          <div class="splide__slide">
            <div class="hero-slide-{{ section.id }}">
              <picture>
                {% if block.settings.mobile_image != blank %}
                  <source
                    media="(max-width: 768px)"
                    srcset="
                      {{ block.settings.mobile_image | image_url: width: 400 }} 400w,
                      {{ block.settings.mobile_image | image_url: width: 600 }} 600w
                    "
                    sizes="100vw"
                  >
                {% endif %}

                <img
                  src="{{ block.settings.desktop_image | image_url: width: 600 }}"
                  srcset="
                    {{ block.settings.desktop_image | image_url: width: 400 }} 400w,
                    {{ block.settings.desktop_image | image_url: width: 600 }} 600w,
                    {{ block.settings.desktop_image | image_url: width: 800 }} 800w,
                    {{ block.settings.desktop_image | image_url: width: 1000 }} 1000w
                  "
                  sizes="(max-width: 768px) 100vw, 595px"
                  alt="{{ block.settings.heading | escape }}"
                  width="1800"
                  height="1000"
                  decoding="async"
                  {% if forloop.first %}
                    loading="eager"
                    fetchpriority="high"
                    preload: true
                  {% else %}
                    loading="lazy"
                    fetchpriority="low"
                  {% endif %}
                >
              </picture>
              <div class="hero-overlay-{{ section.id }}"></div>

              <div class="hero-content-{{ section.id }} align-{{ block.settings.text_align }}">
                <h2 class="hero-heading-{{ section.id }}">
                  {{ block.settings.heading }}
                </h2>

                <p class="hero-text-{{ section.id }}">
                  {{ block.settings.subtext }}
                </p>

                {% if block.settings.btn_label != blank %}
                  <a href="{{ block.settings.btn_link }}" class="hero-btn-{{ section.id }}">
                    {{ block.settings.btn_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>


{% schema %}
{
  "name": "Premium Hero Splide",
  "settings": [
    {
      "type": "text",
      "id": "aspect_ratio",
      "label": "Aspect Ratio (e.g. 16/7)",
      "default": "16/7"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 0.7,
      "step": 0.1,
      "default": 0.3,
      "label": "Overlay Opacity"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#ffffff",
      "label": "Text Color"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "default": 42,
      "label": "Heading Size"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 22,
      "default": 16,
      "label": "Subtext Size"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "default": "#7A0F1D",
      "label": "Button BG"
    },
    {
      "type": "color",
      "id": "btn_color",
      "default": "#ffffff",
      "label": "Button Text"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "default": true,
      "label": "Autoplay"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "default": 5,
      "label": "Autoplay Speed (sec)"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": true,
      "label": "Show Arrows"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "default": true,
      "label": "Show Pagination"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "desktop_image", "label": "Desktop Image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile Image (optional)" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "subtext", "label": "Subtext" },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        { "type": "text", "id": "btn_label", "label": "Button Label" },
        { "type": "url", "id": "btn_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Hero Splide",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}


<script>
  document.addEventListener('DOMContentLoaded', function () {
     var isMobile = window.innerWidth <= 768;
    setTimeout(() => {
      new Splide('.splide-hero-{{ section.id }}', {
        type: 'loop',
        perPage: 1,
        autoplay: {{ section.settings.autoplay }},
        interval: {{ section.settings.autoplay_speed }} * 1000,
        pauseOnHover: isMobile ? false : true,
        arrows: {{ section.settings.show_arrows }},
        pagination: {{ section.settings.show_dots }},
        speed: 800
      }).mount();
    }, 50);
  });
</script>
