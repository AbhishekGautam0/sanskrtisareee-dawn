{% comment %}
  ┌─────────────────────────────────────────────────────────────┐
  │   TRUST BAR — Icon + Title + Subtitle blocks                │
  │   Shopify Dawn Theme                                        │
  │   · Up to 6 feature blocks                                  │
  │   · SVG icon picker (built-in set) OR custom image          │
  │   · Divider lines between items                             │
  │   · Full schema: colors, typography, spacing, layout        │
  │   · Fully responsive — stacks on mobile                     │
  └─────────────────────────────────────────────────────────────┘
{% endcomment %}

{%- liquid
  assign heading_font = section.settings.heading_font
  assign body_font    = section.settings.body_font
-%}


<style>
/* ============================================================
   CSS VARIABLES
   ============================================================ */
#shopify-section-{{ section.id }} {
  --tb-bg:           {{ section.settings.bg_color }};
  --tb-border-color: {{ section.settings.border_color }};
  --tb-icon-color:   {{ section.settings.icon_color }};
  --tb-title-color:  {{ section.settings.title_color }};
  --tb-sub-color:    {{ section.settings.subtitle_color }};
  --tb-divider:      {{ section.settings.divider_color }};
  --tb-pad-v:        {{ section.settings.padding_v }}px;
  --tb-pad-h:        {{ section.settings.padding_h }}px;
  --tb-icon-size:    {{ section.settings.icon_size }}px;
  --tb-gap:          {{ section.settings.item_gap }}px;
  --tb-title-size:   {{ section.settings.title_size }}px;
  --tb-sub-size:     {{ section.settings.subtitle_size }}px;
  --tb-radius:       {{ section.settings.section_radius }}px;
}

/* ============================================================
   SECTION WRAPPER
   ============================================================ */
.tb-section {
  background: var(--tb-bg);
  padding: var(--tb-pad-v) var(--tb-pad-h);
  {% if section.settings.show_border_top %}
    border-top: 1px solid var(--tb-border-color);
  {% endif %}
  {% if section.settings.show_border_bottom %}
    border-bottom: 1px solid var(--tb-border-color);
  {% endif %}
  border-radius: var(--tb-radius);
}

.tb-inner {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: {{ section.settings.justify }};
  gap: 0;
  flex-wrap: wrap;
}

/* ============================================================
   SINGLE FEATURE ITEM
   ============================================================ */
.tb-item {
  display: flex;
  align-items: center;
  gap: {{ section.settings.icon_text_gap }}px;
  flex: 1 1 0;
  min-width: 200px;
  padding: {{ section.settings.item_pad_v }}px {{ section.settings.item_pad_h }}px;

  {% case section.settings.item_align %}
    {% when 'center' %}
      flex-direction: column;
      text-align: center;
    {% when 'top' %}
      align-items: flex-start;
    {% else %}
      align-items: center;
  {% endcase %}
}

/* Divider between items */
.tb-item + .tb-item {
  {% if section.settings.show_divider %}
    border-left: 1px solid var(--tb-divider);
  {% endif %}
}

/* ============================================================
   ICON
   ============================================================ */
.tb-icon {
  flex-shrink: 0;
  width: var(--tb-icon-size);
  height: var(--tb-icon-size);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--tb-icon-color);
}

.tb-icon svg {
  width: 100%;
  height: 100%;
  fill: none;
  stroke: var(--tb-icon-color);
  stroke-width: {{ section.settings.icon_stroke_width }};
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* When using image icon */
.tb-icon img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: {{ section.settings.icon_filter }};
}

/* ============================================================
   TEXT
   ============================================================ */
.tb-text {
  display: flex;
  flex-direction: column;
  gap: {{ section.settings.title_sub_gap }}px;
}

.tb-title {
  font-family: {{ heading_font.family }}, sans-serif;
  font-size: var(--tb-title-size);
  font-weight: {{ section.settings.title_weight }};
  color: var(--tb-title-color);
  margin: 0;
  line-height: 1.2;
  letter-spacing: {{ section.settings.title_spacing }}em;
}

.tb-subtitle {
  font-family: {{ body_font.family }}, sans-serif;
  font-size: var(--tb-sub-size);
  font-weight: {{ section.settings.subtitle_weight }};
  color: var(--tb-sub-color);
  margin: 0;
  line-height: 1.45;
}

/* ============================================================
   MOBILE
   ============================================================ */
@media (max-width: {{ section.settings.mobile_breakpoint }}px) {
  .tb-inner {
    flex-direction: {% if section.settings.mobile_layout == 'grid' %}row{% else %}column{% endif %};
    {% if section.settings.mobile_layout == 'grid' %}
      flex-wrap: wrap;
      justify-content: center;
    {% endif %}
    gap: 0;
  }

  .tb-item {
    {% if section.settings.mobile_layout == 'grid' %}
      flex: 0 0 calc(50% - {{ section.settings.item_pad_h }}px);
      min-width: 0;
    {% else %}
      flex: none;
      width: 100%;
    {% endif %}
    border-left: none !important;
    {% if section.settings.mobile_show_divider %}
      border-bottom: 1px solid var(--tb-divider);
    {% endif %}
    {% if section.settings.mobile_center %}
      justify-content: center;
      text-align: center;
      flex-direction: {% if section.settings.item_align == 'center' %}column{% else %}row{% endif %};
    {% endif %}
  }

  .tb-item:last-child {
    border-bottom: none;
  }

  .tb-title {
    font-size: {{ section.settings.title_size | times: 0.9 | round }}px;
  }

  .tb-subtitle {
    font-size: {{ section.settings.subtitle_size | times: 0.9 | round }}px;
  }

  .tb-icon {
    width: {{ section.settings.icon_size | times: 0.85 | round }}px;
    height: {{ section.settings.icon_size | times: 0.85 | round }}px;
  }
}
</style>

