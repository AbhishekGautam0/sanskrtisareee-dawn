<section class="tb-section" id="shopify-section-{{ section.id }}-wrap">
  <div class="tb-inner">

    {%- for block in section.blocks -%}
      {%- if block.type == 'feature' -%}
        <div class="tb-item" {{ block.shopify_attributes }}>

          {%- comment -%} ── Icon ── {%- endcomment -%}
          {%- unless block.settings.icon_choice == 'none' -%}
            <div class="tb-icon">
              {%- if block.settings.custom_image != blank -%}
                {{ block.settings.custom_image | image_url: width: 120 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                {%- case block.settings.icon_choice -%}
                  {%- when 'shipping' -%}  {{ svg_shipping }}
                  {%- when 'support' -%}   {{ svg_support }}
                  {%- when 'payment' -%}   {{ svg_payment }}
                  {%- when 'returns' -%}   {{ svg_returns }}
                  {%- when 'quality' -%}   {{ svg_quality }}
                  {%- when 'secure' -%}    {{ svg_secure }}
                  {%- when 'gift' -%}      {{ svg_gift }}
                  {%- when 'handmade' -%}  {{ svg_handmade }}
                {%- endcase -%}
              {%- endif -%}
            </div>
          {%- endunless -%}

          {%- comment -%} ── Text ── {%- endcomment -%}
          <div class="tb-text">
            {%- if block.settings.title != blank -%}
              <p class="tb-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <p class="tb-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>

        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section-trust-bar",
  "max_blocks": 6,
  "settings": [

    {
      "type": "header",
      "content": "🎨 Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#6b6560"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Top / Bottom Border Color",
      "default": "#e8e3dc"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Between Items",
      "default": "#e8e3dc"
    },

    {
      "type": "header",
      "content": "🔤 Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Title Font",
      "default": "assistant_n7"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Title Font Size",
      "default": 15
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "title_spacing",
      "label": "Title Letter Spacing",
      "options": [
        { "value": "0",    "label": "None" },
        { "value": "0.01", "label": "Tight (0.01em)" },
        { "value": "0.02", "label": "Normal (0.02em)" },
        { "value": "0.05", "label": "Wide (0.05em)" }
      ],
      "default": "0"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Subtitle Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Subtitle Font Size",
      "default": 13
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitle Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },

    {
      "type": "header",
      "content": "🖼 Icon Style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 28,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Icon Size",
      "default": 48
    },
    {
      "type": "select",
      "id": "icon_stroke_width",
      "label": "Icon Stroke Width",
      "options": [
        { "value": "1",   "label": "Thin (1px)" },
        { "value": "1.5", "label": "Regular (1.5px)" },
        { "value": "2",   "label": "Medium (2px)" },
        { "value": "2.5", "label": "Bold (2.5px)" }
      ],
      "default": "1.5"
    },
    {
      "type": "select",
      "id": "icon_filter",
      "label": "Custom Image Icon — Color Filter",
      "options": [
        { "value": "none",       "label": "Original Color" },
        { "value": "grayscale(1)", "label": "Black & White" },
        { "value": "invert(1)",   "label": "Invert (for dark bg)" }
      ],
      "default": "grayscale(1)"
    },

    {
      "type": "header",
      "content": "📐 Layout & Spacing"
    },
    {
      "type": "select",
      "id": "item_align",
      "label": "Icon & Text Alignment",
      "options": [
        { "value": "center-row", "label": "Icon Left, Text Center-Aligned" },
        { "value": "top",        "label": "Icon Left, Text Top-Aligned" },
        { "value": "center",     "label": "Icon Above, Text Centered" }
      ],
      "default": "center-row"
    },
    {
      "type": "select",
      "id": "justify",
      "label": "Items Justify",
      "options": [
        { "value": "space-around",  "label": "Space Around" },
        { "value": "space-between", "label": "Space Between" },
        { "value": "center",        "label": "Center" },
        { "value": "flex-start",    "label": "Left" }
      ],
      "default": "space-around"
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Gap: Icon → Text",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_sub_gap",
      "min": 2,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Gap: Title → Subtitle",
      "default": 4
    },
    {
      "type": "range",
      "id": "item_pad_v",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Item Vertical Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "item_pad_h",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Item Horizontal Padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "label": "Section Max Width",
      "default": 1280
    },
    {
      "type": "range",
      "id": "padding_v",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Section Vertical Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_h",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Section Horizontal Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Section Border Radius",
      "default": 0
    },

    {
      "type": "header",
      "content": "🔲 Borders & Dividers"
    },
    {
      "type": "checkbox",
      "id": "show_border_top",
      "label": "Show Top Border",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "Show Bottom Border",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Divider Between Items",
      "default": true
    },

    {
      "type": "header",
      "content": "📱 Mobile"
    },
    {
      "type": "range",
      "id": "mobile_breakpoint",
      "min": 480,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 650,
      "label": "Mobile Breakpoint",
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "options": [
        { "value": "stack",  "label": "Stack (1 column)" },
        { "value": "grid",   "label": "Grid (2 columns)" }
      ],
      "default": "stack"
    },
    {
      "type": "checkbox",
      "id": "mobile_center",
      "label": "Center Items on Mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "mobile_show_divider",
      "label": "Show Divider Between Items on Mobile",
      "default": true
    }

  ],

  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "select",
          "id": "icon_choice",
          "label": "Icon",
          "options": [
            { "value": "shipping",  "label": "🚚 International Shipping" },
            { "value": "support",   "label": "🎧 Online Support" },
            { "value": "payment",   "label": "💳 Flexible Payment" },
            { "value": "returns",   "label": "↩️ Easy Returns" },
            { "value": "quality",   "label": "⭐ Premium Quality" },
            { "value": "secure",    "label": "🔒 Secure Shopping" },
            { "value": "gift",      "label": "🎁 Gift Wrapping" },
            { "value": "handmade",  "label": "✋ Handmade" },
            { "value": "none",      "label": "No Icon" }
          ],
          "default": "shipping"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Icon Image",
          "info": "Overrides the built-in icon above. Use a square PNG/SVG."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "International Shipping"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Free Shipping for orders over ₹25,000"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_choice": "shipping",
            "title": "International Shipping",
            "subtitle": "Free Shipping for orders over ₹25,000"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_choice": "support",
            "title": "Online Support",
            "subtitle": "24 hours a day, 7 days a week"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_choice": "payment",
            "title": "Flexible Payment",
            "subtitle": "Multiple payment options"
          }
        }
      ]
    }
  ]
}
{% endschema %}
