      "label": "Menu Heading"
    },
    {
      "type": "link_list",
      "id": "menu1",
      "label": "Menu 1"
    },
    {
      "type": "text",
      "id": "menu_text2",
      "label": "Menu Heading"
    },
    {
      "type": "link_list",
      "id": "menu2",
      "label": "Menu 2"
    },
    {
      "type": "text",
      "id": "newsletter_head",
      "label": "Newsletter Heading"
    },
    {
      "type": "text",
      "id": "newsletter_desc",
      "label": "Newsletter Description"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Social Media",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
