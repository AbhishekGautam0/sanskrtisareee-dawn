        },
        {
          "type": "url",
          "id": "url",
          "label": "Social media URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
