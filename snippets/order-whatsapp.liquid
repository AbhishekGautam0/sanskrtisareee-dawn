{% assign phone_number = block.settings.number %}
{% assign phone_number = '91' | append: phone_number %}

{% assign message = "Hi, I'm interested in this saree: "
  | append: product.title
  | append: " - "
  | append: shop.url
  | append: product.url
%}

<a
  href="https://wa.me/{{ phone_number }}?text={{ message | url_encode }}"
  target="_blank"
  class="whatsapp-order-btn"
>
  <span class="wa-icon">
    <svg width="18" height="18" viewBox="0 0 32 32" fill="white">
      <path d="M16 .5C7.5.5.5 7.5.5 16c0 2.8.7 5.5 2 7.9L.5 31.5l7.8-2c2.3 1.2 4.9 1.8 7.7 1.8 8.5 0 15.5-7 15.5-15.5S24.5.5 16 .5zm0 28c-2.4 0-4.7-.6-6.7-1.7l-.5-.3-4.6 1.2 1.2-4.5-.3-.5C4.1 20.7 3.5 18.4 3.5 16 3.5 9.1 9.1 3.5 16 3.5S28.5 9.1 28.5 16 22.9 28.5 16 28.5z"/>
    </svg>
  </span>

  <span>Order via WhatsApp</span>
</a>
